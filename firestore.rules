rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 用戶個人資料
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 訂單：所有人可讀（for 店鋪展示）
    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 倉存：已登入用戶可讀寫
    match /inventory/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 倉存記錄：已登入用戶可讀寫（admin 額外刪除權）
    match /inventory_transactions/{txId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.token.email == 'admin@yauhing.hk';
    }

    // 員工資料：已登入用戶可讀（SM 都可以睇員工名單）
    // 寫入（新增/編輯/刪除）：僅 admin@yauhing.hk
    match /employees/{empId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.email == 'admin@yauhing.hk';
      allow update: if request.auth != null && request.auth.token.email == 'admin@yauhing.hk';
      allow delete: if request.auth != null && request.auth.token.email == 'admin@yauhing.hk';
    }

    // 管理員帳戶：已登入用戶可讀取自己的資料
    // 寫入：僅 admin@yauhing.hk
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if request.auth != null && request.auth.token.email == 'admin@yauhing.hk';
    }

    // 打卡記錄：所有已登入用戶可讀寫
    // 包括：admin、SM、員工都可以打卡
    match /checkins/{checkinId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.token.email == 'admin@yauhing.hk';
    }
  }
}
